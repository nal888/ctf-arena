# Copy to .env and fill in.  Most people only need the first two lines.
CTFD_URL=https://your-ctf.example.com
CTFD_TOKEN=your_api_token_here
# CTFD_COOKIE=             # use instead of token if API tokens are disabled

# --- optional tuning (sensible defaults) ---
PREFIX=flag                # flag format prefix, e.g. MPTC
RACERS=1                   # 1 = normal (single solver + critic); 3 = crazy (parallel race, ~3x tokens)
SUBMIT=auto                # auto = submit verified flags; manual = surface only (you submit)
SKIP_OSINT=0               # 1 = skip osint
DEADLINE=                  # comp end, e.g. 2026-07-15 10:00 UTC (empty = none)
